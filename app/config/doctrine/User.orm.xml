<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="https://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="https://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="App\Modules\Identity\Domain\User\User" table="users">
        <id name="id" type="string" length="36" column="id">
            <generator strategy="NONE" />
        </id>
        <field name="academyId" type="string" length="36" column="academy_id" nullable="true" />
        <field name="email" type="string" length="180" unique="true" />
        <field name="password" type="string" length="255" column="password_hash" />
        <field name="roles" type="json" column="roles" nullable="true" />
        <field name="status" type="string" length="20" nullable="true" />
    </entity>
</doctrine-mapping>
