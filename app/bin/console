<?php

declare(strict_types=1);

use App\Kernel;
use Symfony\Bundle\FrameworkBundle\Console\Application;
use Symfony\Component\Console\Input\ArgvInput;
use Symfony\Component\Console\Output\ConsoleOutput;
use Symfony\Component\ErrorHandler\Debug;

require dirname(__DIR__).'/vendor/autoload.php';

$input = new ArgvInput();
$defaultEnv = getenv('APP_ENV') ?: ($_SERVER['APP_ENV'] ?? 'dev');
$env = $input->getParameterOption(['--env', '-e'], $defaultEnv, true);
$debugEnv = getenv('APP_DEBUG');
if (false === $debugEnv) {
    $debugEnv = $_SERVER['APP_DEBUG'] ?? ($env !== 'prod');
}
$debug = filter_var($debugEnv, FILTER_VALIDATE_BOOL, FILTER_NULL_ON_FAILURE);
$debug = null === $debug ? (bool) $debugEnv : $debug;

if ($debug && class_exists(Debug::class)) {
    Debug::enable();
}

$kernel = new Kernel($env, $debug);
$application = new Application($kernel);
$application->run($input, new ConsoleOutput());
