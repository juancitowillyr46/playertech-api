<?xml version="1.0" encoding="UTF-8" ?>
<doctrine-mapping
    xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://doctrine-project.org/schemas/orm/doctrine-mapping
        https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity
        name="App\Modules\Academy\Domain\Academy\Academy"
        table="academies">

        <unique-constraints>
            <unique-constraint
                name="UNIQ_ACADEMIES_CONTACT_EMAIL"
                columns="contact_email"/>
        </unique-constraints>

        <indexes>
            <index
                name="IDX_ACADEMIES_STATUS"
                columns="status"/>

            <index
                name="IDX_ACADEMIES_CREATED_BY"
                columns="created_by"/>

            <index
                name="IDX_ACADEMIES_UPDATED_BY"
                columns="updated_by"/>

            <index
                name="IDX_ACADEMIES_DELETED_BY"
                columns="deleted_by"/>
        </indexes>

        <id
            name="id"
            column="id"
            type="academy_id"/>

        <embedded
            name="name"
            class="App\Shared\Domain\ValueObject\Name"
            use-column-prefix="false"/>

        <embedded
            name="contactEmail"
            class="App\Shared\Domain\ValueObject\Email"
            use-column-prefix="false"/>

        <embedded
            name="phone"
            class="App\Shared\Domain\ValueObject\PhoneNumber"
            use-column-prefix="false"/>

        <field
            name="country"
            column="country"
            type="string"
            length="80"
            nullable="true"/>

        <field
            name="department"
            column="department"
            type="string"
            length="80"
            nullable="true"/>

        <field
            name="taxIdType"
            column="tax_id_type"
            type="string"
            length="40"
            nullable="true"/>

        <field
            name="taxIdNumber"
            column="tax_id_number"
            type="string"
            length="40"
            nullable="true"/>

        <field
            name="taxRegime"
            column="tax_regime"
            type="string"
            length="80"
            nullable="true"/>

        <field
            name="billingEmail"
            column="billing_email"
            type="string"
            length="180"
            nullable="true"/>

        <field
            name="registrationSource"
            column="registration_source"
            type="string"
            length="20"/>

        <embedded
            name="address"
            class="App\Shared\Domain\ValueObject\Address"
            use-column-prefix="false"/>

        <embedded
            name="city"
            class="App\Shared\Domain\ValueObject\City"
            use-column-prefix="false"/>

        <embedded
            name="shield"
            class="App\Shared\Domain\ValueObject\Media"
            use-column-prefix="true"
            column-prefix="shield_"/>

        <embedded
            name="status"
            class="App\Modules\Academy\Domain\Academy\AcademyStatus"
            use-column-prefix="false"/>

        <embedded
            name="auditTrail"
            class="App\Shared\Domain\ValueObject\AuditTrail"
            use-column-prefix="false"/>

        <field
            name="deletedAt"
            column="deleted_at"
            type="datetime_immutable"
            nullable="true"/>

        <field
            name="deletedBy"
            column="deleted_by"
            type="guid"
            nullable="true"/>

    </entity>

</doctrine-mapping>
