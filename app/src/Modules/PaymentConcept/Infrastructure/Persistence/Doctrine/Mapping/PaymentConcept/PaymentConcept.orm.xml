<?xml version="1.0" encoding="UTF-8" ?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="App\Modules\PaymentConcept\Domain\PaymentConcept\PaymentConcept" table="payment_concepts">
        <unique-constraints>
            <unique-constraint name="UNIQ_PAYMENT_CONCEPT_ACADEMY_CODE" columns="academy_id,code"/>
        </unique-constraints>
        <indexes>
            <index name="IDX_PAYMENT_CONCEPT_ACADEMY" columns="academy_id"/>
            <index name="IDX_PAYMENT_CONCEPT_STATUS" columns="status"/>
        </indexes>
        <id name="id" column="id" type="payment_concept_id"/>
        <field name="academyId" column="academy_id" type="academy_id"/>
        <field name="code" column="code" type="string" length="50"/>
        <field name="name" column="name" type="string" length="100"/>
        <field name="description" column="description" type="string" length="250" nullable="true"/>
        <embedded name="status" class="App\Modules\PaymentConcept\Domain\PaymentConcept\PaymentConceptStatus" use-column-prefix="false"/>
        <embedded name="auditTrail" class="App\Shared\Domain\ValueObject\AuditTrail" use-column-prefix="false"/>
        <field name="deletedAt" column="deleted_at" type="datetime_immutable" nullable="true"/>
        <field name="deletedBy" column="deleted_by" type="guid" nullable="true"/>
    </entity>
</doctrine-mapping>
