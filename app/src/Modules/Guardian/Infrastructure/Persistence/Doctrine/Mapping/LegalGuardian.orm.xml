<?xml version="1.0" encoding="UTF-8" ?>
<doctrine-mapping
    xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://doctrine-project.org/schemas/orm/doctrine-mapping
        https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity
        name="App\Modules\Guardian\Domain\LegalGuardian\LegalGuardian"
        table="legal_guardians">

        <unique-constraints>
            <unique-constraint
                name="UNIQ_LEGAL_GUARDIAN_ACADEMY_EMAIL"
                columns="academy_id,email"/>
        </unique-constraints>

        <indexes>
            <index
                name="IDX_LEGAL_GUARDIAN_ACADEMY"
                columns="academy_id"/>

            <index
                name="IDX_LEGAL_GUARDIAN_STATUS"
                columns="status"/>

            <index
                name="IDX_LEGAL_GUARDIAN_CREATED_BY"
                columns="created_by"/>

            <index
                name="IDX_LEGAL_GUARDIAN_UPDATED_BY"
                columns="updated_by"/>

            <index
                name="IDX_LEGAL_GUARDIAN_DELETED_BY"
                columns="deleted_by"/>
        </indexes>

        <id
            name="id"
            column="id"
            type="legal_guardian_id"/>

        <field
            name="academyId"
            column="academy_id"
            type="academy_id"/>

        <field
            name="firstName"
            column="first_name"
            type="string"
            length="100"/>

        <field
            name="lastName"
            column="last_name"
            type="string"
            length="100"/>

        <field
            name="phone"
            column="phone"
            type="string"
            length="30"
            nullable="true"/>

        <field
            name="email"
            column="email"
            type="string"
            length="255"
            nullable="true"/>

        <field
            name="documentType"
            column="document_type"
            type="string"
            length="50"
            nullable="true"/>

        <field
            name="documentNumber"
            column="document_number"
            type="string"
            length="30"
            nullable="true"/>

        <field
            name="address"
            column="address"
            type="string"
            length="255"
            nullable="true"/>

        <field
            name="relationship"
            column="relationship"
            type="string"
            length="50"/>

        <embedded
            name="status"
            class="App\Modules\Guardian\Domain\LegalGuardian\LegalGuardianStatus"
            use-column-prefix="false"/>

        <embedded
            name="auditTrail"
            class="App\Shared\Domain\ValueObject\AuditTrail"
            use-column-prefix="false"/>

        <field
            name="deletedAt"
            column="deleted_at"
            type="datetime_immutable"
            nullable="true"/>

        <field
            name="deletedBy"
            column="deleted_by"
            type="guid"
            nullable="true"/>
    </entity>

</doctrine-mapping>
