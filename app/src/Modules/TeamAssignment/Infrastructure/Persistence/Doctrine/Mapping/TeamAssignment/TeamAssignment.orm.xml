<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="App\Modules\TeamAssignment\Domain\TeamAssignment\TeamAssignment" table="team_assignments">
        <unique-constraints>
            <unique-constraint name="UNIQ_TEAM_ASSIGNMENT_ACADEMY_PLAYER_TEAM" columns="academy_id,player_id,team_id"/>
        </unique-constraints>
        <indexes>
            <index name="IDX_TEAM_ASSIGNMENT_ACADEMY" columns="academy_id"/>
            <index name="IDX_TEAM_ASSIGNMENT_PLAYER" columns="player_id"/>
            <index name="IDX_TEAM_ASSIGNMENT_TEAM" columns="team_id"/>
            <index name="IDX_TEAM_ASSIGNMENT_PRIMARY" columns="is_primary"/>
        </indexes>
        <id name="id" column="id" type="team_assignment_id"/>
        <field name="academyId" column="academy_id" type="academy_id"/>
        <field name="playerId" column="player_id" type="player_id"/>
        <field name="teamId" column="team_id" type="team_id"/>
        <field name="startDate" column="start_date" type="date_immutable"/>
        <field name="endDate" column="end_date" type="date_immutable" nullable="true"/>
        <field name="isPrimary" column="is_primary" type="boolean"/>
        <embedded name="auditTrail" class="App\Shared\Domain\ValueObject\AuditTrail" use-column-prefix="false"/>
        <field name="deletedAt" column="deleted_at" type="datetime_immutable" nullable="true"/>
        <field name="deletedBy" column="deleted_by" type="guid" nullable="true"/>
    </entity>
</doctrine-mapping>
