<?xml version="1.0" encoding="UTF-8"?>

<doctrine-mapping
    xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://doctrine-project.org/schemas/orm/doctrine-mapping
        https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity
        name="App\Modules\Team\Domain\Team\Team"
        table="teams">

        <indexes>

            <index
                name="IDX_TEAM_ACADEMY"
                columns="academy_id"/>

            <index
                name="IDX_TEAM_CATEGORY"
                columns="category_id"/>

            <index
                name="IDX_TEAM_STATUS"
                columns="status"/>

            <index
                name="IDX_TEAM_CREATED_BY"
                columns="created_by"/>

            <index
                name="IDX_TEAM_UPDATED_BY"
                columns="updated_by"/>

            <index
                name="IDX_TEAM_DELETED_BY"
                columns="deleted_by"/>

        </indexes>

        <id
            name="id"
            column="id"
            type="team_id"/>

        <field name="academyId" column="academy_id" type="academy_id"/>

        <field name="categoryId" column="category_id" type="category_id"/>

        <embedded
            name="name"
            class="App\Shared\Domain\ValueObject\Name"
            use-column-prefix="false"/>

        <embedded
            name="status"
            class="App\Modules\Team\Domain\Team\TeamStatus"
            use-column-prefix="false"/>

        <embedded
            name="auditTrail"
            class="App\Shared\Domain\ValueObject\AuditTrail"
            use-column-prefix="false"/>

        <field
            name="deletedAt"
            column="deleted_at"
            type="datetime_immutable"
            nullable="true"/>

        <field
            name="deletedBy"
            column="deleted_by"
            type="guid"
            nullable="true"/>

    </entity>

</doctrine-mapping>
