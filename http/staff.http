@baseUrl = http://localhost:8081
@tenantToken = replace-with-tenant-token
@userId = replace-with-user-id
@teamId = replace-with-team-id
@assignmentId = replace-with-assignment-id

### Register Staff Member
POST {{baseUrl}}/api/v1/academy/staff
Authorization: Bearer {{tenantToken}}
Content-Type: application/json
Accept: application/json

{
  "user_id": "{{userId}}"
}

### Assign Staff To Team
POST {{baseUrl}}/api/v1/academy/staff/assignments
Authorization: Bearer {{tenantToken}}
Content-Type: application/json
Accept: application/json

{
  "staff_id": "{{userId}}",
  "team_id": "{{teamId}}",
  "role": "HEAD_COACH"
}

### Change Staff Role
PATCH {{baseUrl}}/api/v1/academy/staff/assignments/{{assignmentId}}/role
Authorization: Bearer {{tenantToken}}
Content-Type: application/json
Accept: application/json

{
  "role": "ASSISTANT_COACH"
}

### Remove Staff From Team
PATCH {{baseUrl}}/api/v1/academy/staff/assignments/{{assignmentId}}/remove
Authorization: Bearer {{tenantToken}}
Accept: application/json

### View Team Staff
GET {{baseUrl}}/api/v1/academy/staff/teams/{{teamId}}
Authorization: Bearer {{tenantToken}}
Accept: application/json
