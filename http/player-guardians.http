@baseUrl = http://localhost:8081
@adminEmail = admin@playertech.com
@adminPassword = secret123
@playerId = {{playerId}}
@guardianId = {{guardianId}}

### Login root success
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json
Accept: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

> {% client.global.set("token", response.body.data.token); %}

### Associate guardian success
POST {{baseUrl}}/api/v1/academy/players/{{playerId}}/guardians
Authorization: Bearer {{token}}
Content-Type: application/json
Accept: application/json

{
  "guardian_id": "{{guardianId}}",
  "is_primary": true
}

### Associate guardian error duplicate
POST {{baseUrl}}/api/v1/academy/players/{{playerId}}/guardians
Authorization: Bearer {{token}}
Content-Type: application/json
Accept: application/json

{
  "guardian_id": "{{guardianId}}",
  "is_primary": true
}

### Change primary guardian
PATCH {{baseUrl}}/api/v1/academy/players/{{playerId}}/guardians/{{guardianId}}/primary
Authorization: Bearer {{token}}
Accept: application/json

### Remove guardian association
DELETE {{baseUrl}}/api/v1/academy/players/{{playerId}}/guardians/{{guardianId}}
Authorization: Bearer {{token}}
Accept: application/json
