@baseUrl = http://localhost:8081
@tenantToken = replace-with-tenant-token
@playerId = replace-with-player-id
@guardianId = replace-with-guardian-id

### Create Membership
POST {{baseUrl}}/api/v1/academy/memberships
Authorization: Bearer {{tenantToken}}
Content-Type: application/json
Accept: application/json

{
  "player_id": "{{playerId}}",
  "primary_guardian_id": "{{guardianId}}"
}

### Show Active Membership
GET {{baseUrl}}/api/v1/academy/memberships/{{playerId}}/active
Authorization: Bearer {{tenantToken}}
Accept: application/json

### Suspend Membership
PATCH {{baseUrl}}/api/v1/academy/memberships/{{playerId}}/suspend
Authorization: Bearer {{tenantToken}}
Accept: application/json

### Withdraw Membership
PATCH {{baseUrl}}/api/v1/academy/memberships/{{playerId}}/withdraw
Authorization: Bearer {{tenantToken}}
Accept: application/json
